{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
  "types": [
    "node"
  ],
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],
    "module": "nodenext",
    "target": "es2022",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "*": ["../../*"],
      "@vonage/*": [
        "../packages/*/lib"
      ]
    }
  },
  "ts-node": {
    "esm": true,
    "skipLibCheck": false
  }
}
