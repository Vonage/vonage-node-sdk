{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@vonage/server-client",
  "version": "1.19.4",
  "description": "The Vonage Server Client provides core functionalities for interacting with Vonage APIs, ensuring a standardized response regardless of the underlying HTTP adapter.",
  "homepage": "https://developer.vonage.com",
  "bugs": {
    "url": "https://github.com/Vonage/vonage-node-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vonage/vonage-node-sdk.git"
  },
  "license": "Apache-2.0",
  "contributors": [
    {
      "name": "Chris Tankersley",
      "url": "https://github.com/dragonmantank"
    },
    {
      "name": "Chuck \"MANCHUCK\" Reeves",
      "url": "https://github.com/manchuck"
    }
  ],
  "type": "commonjs",
  "exports": {
    ".": {
      "workerd": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "deno": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "bun": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "edge-light": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "netlify": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "fastly": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "react-native": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "react-server": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "electron": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "edge-routine": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "lagon": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "wasmer": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "moddable": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "arvancloud": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "azion": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "kiesel": {
        "import": {
          "default": "./dist/esm/index.mjs"
        },
        "require": {
          "default": "./dist/cjs/index.js"
        }
      },
      "browser": "./dist/unsupportedBrowser.cjs",
      "import": {
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "postbuild": "node ../../scripts/copyUnsupported.cjs && node -e \"const fs=require('node:fs'),p='dist/cjs/package.json';fs.mkdirSync('dist/cjs',{recursive:true});fs.writeFileSync(p,JSON.stringify({type:'commonjs'},null,2));\"",
    "build:cjs": "esbuild lib/*.js lib/**/*.js --platform=node --format=cjs --outdir=dist/cjs --out-extension:.js=.js",
    "build:esm": "esbuild lib/*.js lib/**/*.js --platform=node --format=esm --outdir=dist/esm --out-extension:.js=.mjs",
    "check:pkg": "npx attw --pack .",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vonage/auth": "1.14.4",
    "debug": "4.4.3"
  },
  "devDependencies": {
    "nock": "14.0.10"
  },
  "engines": {
    "node": ">=20"
  },
  "engineStrict": true,
  "publishConfig": {
    "directory": "dist"
  }
}
