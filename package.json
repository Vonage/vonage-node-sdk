{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@vonage/server-sdk-monorepo",
  "version": "3.20.1",
  "private": true,
  "description": "Vonage Server SDK for Node.js. API support for SMS, Voice Calls, Text-to-Speech, Numbers, Verify (2FA) and more.",
  "keywords": [
    "sms",
    "voice",
    "vonage",
    "verify",
    "2fa",
    "phone numbers",
    "identity insights"
  ],
  "homepage": "https://github.com/vonage/vonage-node-sdk",
  "repository": {
    "type": "git",
    "url": "git://github.com/vonage/vonage-node-sdk.git"
  },
  "license": "Apache 2.0",
  "type": "module",
  "author": "vonage",
  "contributors": [
    {
      "name": "Kelly Andrews",
      "url": "https://github.com/kellyjandrews"
    },
    {
      "name": "Chuck \"MANCHUCK\" Reeves",
      "url": "https://github.com/manchuck"
    },
    {
      "name": "Chris Tankersley",
      "url": "https://github.com/dragonmantank"
    }
  ],
  "workspaces": [
    "packages/jwt",
    "packages/auth",
    "packages/vetch",
    "packages/server-client",
    "packages/network-client",
    "packages/accounts",
    "packages/applications",
    "packages/audit",
    "packages/identity-insights",
    "packages/media",
    "packages/messages",
    "packages/network-number-verification",
    "packages/network-sim-swap",
    "packages/number-insight-v2",
    "packages/number-insights",
    "packages/numbers",
    "packages/pricing",
    "packages/redact",
    "packages/reports",
    "packages/sms",
    "packages/subaccounts",
    "packages/users",
    "packages/verify",
    "packages/verify2",
    "packages/video",
    "packages/voice",
    "packages/conversations",
    "packages/server-sdk"
  ],
  "scripts": {
    "postbuild": "npm run check:pkg --workspaces",
    "eslint": "eslint",
    "jest": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepare": "husky",
    "test": "cross-env NODE_NO_WARNINGS=1 NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "test:watch": "cross-env NODE_NO_WARNINGS=1 NODE_OPTIONS=\"--experimental-vm-modules\" jest --watch",
    "tsc": "tsc",
    "typedoc": "typedoc"
  },
  "lint-staged": {
    "build": "lerna run build",
    "package.json": [
      "npx sort-package-json"
    ],
    "*.js": [
      "eslint --fix"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "engineStrict": true,
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@jest/globals": "30.4.1",
    "@tsconfig/node22": "22.0.5",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "26.1.1",
    "@vonage/eslint-config": "1.4.3",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "eslint-plugin-jest": "29.15.4",
    "eslint-plugin-package-json": "1.5.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "jest": "30.4.2",
    "jest-junit": "17.0.0",
    "jsonwebtoken": "9.0.3",
    "lint-staged": "17.0.8",
    "nock": "14.0.16",
    "publint": "0.3.21",
    "recursive-iterator": "3.3.0",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "typedoc": "0.28.20",
    "typedoc-github-wiki-theme": "2.1.0",
    "typedoc-plugin-frontmatter": "1.3.1",
    "typedoc-plugin-markdown": "4.12.0",
    "typedoc-plugin-remark": "2.0.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
